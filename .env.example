# =============================================================================
# Poytakht CRM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── Core ──────────────────────────────────────────────────────────────────────
# Generate SECRET_KEY with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE-ME-generate-a-random-50-char-secret-key

# Set to False in production — True only for local development
DEBUG=False

# ── Hosts & CSRF ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins trusted for CSRF (must include https:// in production)
CSRF_TRUSTED_ORIGINS=https://your-domain.example.com

# ── Database ──────────────────────────────────────────────────────────────────
# Option 1: Full DATABASE_URL — Railway / Heroku style (takes priority)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Individual variables (used if DATABASE_URL is not set)
DB_NAME=poytakht_crm
DB_USER=postgres
DB_PASSWORD=CHANGE-ME-use-a-strong-password
DB_HOST=localhost
DB_PORT=5432

# Option 3: SQLite — local development ONLY, never in production
USE_SQLITE=True

# ── Seed / Demo Data ──────────────────────────────────────────────────────────
# 1 = create demo accounts on startup (local/staging only)
# 0 = skip (always use 0 in production — demo passwords are weak)
RUN_SEED_DATA=0

# ── Railway (automatically set by Railway — do not set manually) ──────────────
# RAILWAY_PUBLIC_DOMAIN=web-production-xxxx.up.railway.app
# PORT=8000
# WEB_CONCURRENCY=2
